# f-launch 用户配置
# 修改后保存即生效，无需重启 Claude Code

settings:
  default_license:
    value: MIT
    description: "默认 LICENSE,可选 MIT / Apache-2.0 / None"
    type: enum
    options: [MIT, Apache-2.0, None]

  git_init:
    value: true
    description: "脚手架生成后是否自动 git init + 首次 commit"
    type: boolean

  wiki_report:
    value: false
    description: "是否默认生成飞书 wiki 报告(技术选型/立项)"
    type: boolean

  okr_association:
    value: true
    description: "是否默认关联 f-logme OKR Base(写 1 O + 2-3 KR)"
    type: boolean

  memory_record:
    value: true
    description: "是否默认写 memory 记录到 ~/.claude/projects/.../memory/"
    type: boolean

  parent_dir:
    value: "~/git"
    description: "脚手架默认父目录"
    type: string

# 8 类项目类型元数据
types:
  static-web-personal:
    complexity: 1
    default_stack: [HTML, CSS, JS-ESM, Leaflet, Supabase(optional), R2(optional)]
    deploy_targets: [cloudflare-pages, netlify, github-pages]
    reference: "~/git/<project-name>"

  web-api-backend:
    complexity: 3
    default_stack: [Node-22, TypeScript, Hono, Drizzle, Zod, Vitest, better-auth]
    deploy_targets: [render, railway, fly-io]
    reference: "~/git/<project-name>"

  cli-tool:
    complexity: 2
    default_stack: [Node-TS / Go / Rust]
    deploy_targets: [npm, homebrew, cargo]
    reference: null

  ai-agent-tool:
    complexity: 3
    default_stack: [Python-3.12, anthropic-sdk, langchain, pydantic]
    deploy_targets: [docker, railway, fly-io]
    reference: null

  data-pipeline:
    complexity: 4
    default_stack: [Python-3.12, airflow / dagster, polars, dbt]
    deploy_targets: [k8s, ecs, self-hosted]
    reference: null

  mobile-app:
    complexity: 4
    default_stack: [React-Native / Flutter]
    deploy_targets: [app-store, google-play]
    reference: null

  desktop-app:
    complexity: 4
    default_stack: [Electron / Tauri]
    deploy_targets: [github-releases, msi / dmg / appimage]
    reference: null

  game:
    complexity: 4
    default_stack: [Godot-4 / Unity-2026]
    deploy_targets: [steam, itch-io, app-store]
    reference: null
