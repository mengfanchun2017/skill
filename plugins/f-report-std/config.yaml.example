# f-report-std 用户配置
# 修改后保存即生效，无需重启 Claude Code

settings:
  default_template:
    value: research
    description: "默认模板（research/analysis/comparison/proposal）"
    type: enum
    options: [research, analysis, comparison, proposal]

  strict_mode:
    value: true
    description: "严格模式：强制每章必有 2-3 句概括"
    type: boolean

  language:
    value: zh
    description: "报告语言（zh/en）"
    type: enum
    options: [zh, en]
